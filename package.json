{
  "name": "breachline-fps-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Original browser tactical FPS prototype spine for WebTransport multiplayer experiments.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/client",
    "apps/server",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:client": "npm run typecheck && node apps/client/dist/dev-client.js",
    "dev:server": "npm run typecheck && node apps/server/dist/dev-server.js",
    "host:match": "npm run typecheck && node scripts/host-match.mjs",
    "audit:private-assets": "npm run typecheck && node scripts/private-asset-audit.mjs",
    "playtest:harness": "node scripts/playtest-harness.mjs",
    "playtest:harness:network": "node scripts/playtest-network-harness.mjs",
    "playtest:notes": "node scripts/playtest-notes.mjs",
    "playtest:review": "node scripts/playtest-review.mjs",
    "smoke:browser-page": "npm run typecheck && node scripts/browser-page-smoke.mjs",
    "smoke:transport": "npm run typecheck && node scripts/transport-loop-smoke.mjs",
    "test": "npm run typecheck && node scripts/run-tests.mjs",
    "typecheck": "tsc -b",
    "validate": "npm run test && npm run smoke:transport && npm run smoke:browser-page"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
